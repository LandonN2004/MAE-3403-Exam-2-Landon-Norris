# region imports
import sys
from PyQt5.QtWidgets import QApplication, QWidget
from P1_GUI import Ui_MainForm
from Circuit_Classes import circuitController
# endregion


# region class definitions
class CircuitApp(QWidget, Ui_MainForm):
    def __init__(self):
        """
        Build the main application window and connect it to the controller.
        """
        super().__init__()

        self.setupUi(self)
        self.setWindowTitle("RLC Circuit Transient Simulator")

        self._collect_widgets()
        self._build_controller()
        self._bind_events()

        self.show()

    def _collect_widgets(self):
        """
        Store input and display widgets in grouped tuples.
        """
        self.input_fields = (
            self.le_Inductance,
            self.le_Resistance,
            self.le_Capacitence,
            self.le_Amplitude,
            self.le_Freq,
            self.le_Phase,
            self.le_simTime,
            self.le_simPts
        )

        self.display_items = (
            self.layout_VertMain,
            self.layout_VertInput,
            self
        )

    def _build_controller(self):
        """
        Create the controller for the circuit simulation.
        """
        self.sim_controller = circuitController((self.input_fields, self.display_items))

    def _bind_events(self):
        """
        Connect GUI signals to methods.
        """
        self.pb_Calculate.clicked.connect(self.run_simulation)

    def run_simulation(self):
        """
        Tell the controller to perform the calculation.
        """
        self.sim_controller.calculate()
# endregion


# region main
def launch_app():
    app = QApplication.instance()

    if app is None:
        app = QApplication(sys.argv)

    app.aboutToQuit.connect(app.deleteLater)

    window = CircuitApp()
    return app.exec_()


if __name__ == "__main__":
    sys.exit(launch_app())
# endregion
