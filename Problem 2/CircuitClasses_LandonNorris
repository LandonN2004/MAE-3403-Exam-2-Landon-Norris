from X2Q2_SP24 import doPlot, simulate
from PyQt5 import QtWidgets as qtw
from PyQt5 import QtGui as qtg
from PyQt5 import QtCore as qtc
from matplotlib.backends.backend_qt5agg import FigureCanvasQTAgg, NavigationToolbar2QT
from matplotlib.figure import Figure
# endregion


# region RLC circuit classes (MVC)
class circuitModel:
    def __init__(self):
        """
        Store circuit-related collections.
        """
        self.nodes = []
        self.resistors = []
        self.capacitors = []
        self.inductors = []
        self.voltageSources = []
        self.wires = []


class circuitView:
    def __init__(self, dw=None):
        """
        Build the visual portion of the application.
        :param dw: tuple containing display widgets
        """
        self.layout_VertMain = None
        self.layout_VertInput = None
        self.form = None
        self.figure = None
        self.canvas = None
        self.ax = None
        self.toolbar = None
        self.image_label = None

        if dw is not None:
            self.assignDisplayWidgets(dw)
            self.buildImageWidget()
            self.buildPlotWidget()

    def assignDisplayWidgets(self, dw):
        """
        Save references to the GUI display widgets.
        :param dw: (layout_VertMain, layout_VertInput, form)
        """
        self.layout_VertMain, self.layout_VertInput, self.form = dw

    def buildImageWidget(self):
        """
        Add the circuit image to the input side of the GUI.
        """
        image = qtg.QPixmap("Circuit1.jpg")
        self.image_label = qtw.QLabel()
        self.image_label.setAlignment(qtc.Qt.AlignCenter)
        self.image_label.setPixmap(image)
        self.layout_VertInput.addWidget(self.image_label)

    def buildPlotWidget(self):
        """
        Create the matplotlib objects used for plotting.
        """
        self.figure = Figure(figsize=(8, 8), tight_layout=True)
        self.canvas = FigureCanvasQTAgg(self.figure)
        self.ax = self.figure.add_subplot()
        self.toolbar = NavigationToolbar2QT(self.canvas, self.form)

        self.layout_VertMain.addWidget(self.toolbar)
        self.layout_VertMain.addWidget(self.canvas)

    def doPlot(self, plotArgs):
        """
        Refresh the graph shown on the GUI.
        :param plotArgs: (R, tList, I)
        """
        self.figure.clear()
        self.ax = self.figure.add_subplot()
        doPlot(plotArgs, ax=self.ax)
        self.canvas.draw()


class circuitController:
    def __init__(self, args):
        """
        Coordinate the model, view, and GUI inputs.
        :param args: (inputWidgets, displayWidgets)
        """
        self.inputWidgets, self.displayWidgets = args
        self._storeInputReferences()

        self.Model = circuitModel()
        self.View = circuitView(self.displayWidgets)

    def _storeInputReferences(self):
        """
        Unpack the line edit widgets used for simulation inputs.
        """
        (
            self.le_Inductance,
            self.le_Resistance,
            self.le_Capacitence,
            self.le_Amplitude,
            self.le_Freq,
            self.le_Phase,
            self.le_simTime,
            self.le_simPts
        ) = self.inputWidgets

    def _getValues(self):
        """
        Read values from the GUI and return them in a dictionary.
        """
        return {
            "L": float(self.le_Inductance.text()),
            "R": float(self.le_Resistance.text()),
            "C": float(self.le_Capacitence.text()),
            "A": float(self.le_Amplitude.text()),
            "f": float(self.le_Freq.text()),
            "p": float(self.le_Phase.text()),
            "t": float(self.le_simTime.text()),
            "pts": float(self.le_simPts.text())
        }

    def calculate(self):
        """
        Run the circuit simulation and display the results.
        """
        values = self._getValues()

        results = simulate(
            L=values["L"],
            R=values["R"],
            C=values["C"],
            A=values["A"],
            f=values["f"],
            p=values["p"],
            t=values["t"],
            pts=values["pts"]
        )

        self.View.doPlot((values["R"], results.t, results))
