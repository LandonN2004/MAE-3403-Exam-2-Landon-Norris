#region imports
import math
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Tuple
import numpy as np
from scipy.optimize import fsolve
#endregion

#region constants
G = 32.174  # ft/s^2

# Water properties from exam statement
MU = 20.50e-6  # lbf*s/ft^2  (treated consistently in English units)
GAMMA = 62.3   # lbf/ft^3
RHO = GAMMA / G  # slug/ft^3
NU = MU / RHO    # ft^2/s

# Roughness values from exam statement
EPS_CAST_IRON = 0.00085  # ft
EPS_CONCRETE = 0.00300   # ft
#endregion

#region helper functions
def psi_to_head_ft(psi: float) -> float:
    """Convert pressure in psi to pressure head in feet of water."""
    return psi * 144.0 / GAMMA

def head_ft_to_psi(head_ft: float) -> float:
    """Convert pressure head in feet of water to pressure in psi."""
    return head_ft * GAMMA / 144.0

def area_circular(diameter_ft: float) -> float:
    """Return circular pipe area in ft^2."""
    return math.pi * diameter_ft**2 / 4.0

def reynolds_number(flow_cfs: float, diameter_ft: float) -> float:
    """Return Reynolds number using |V|D/nu."""
    area = area_circular(diameter_ft)
    velocity = abs(flow_cfs) / area
    return velocity * diameter_ft / NU

def friction_factor_swamee_jain(reynolds: float, roughness_ft: float, diameter_ft: float) -> float:
    """
    Darcy friction factor using:
    - laminar: f = 64/Re
    - turbulent: Swamee-Jain explicit correlation
    """
    if reynolds < 1e-12:
        return 0.02
    if reynolds < 2000.0:
        return 64.0 / reynolds

    return 0.25 / (
        math.log10(roughness_ft / (3.7 * diameter_ft) + 5.74 / (reynolds ** 0.9))
    ) ** 2

def flow_from_headloss(delta_h_ft: float, length_ft: float, diameter_ft: float, roughness_ft: float) -> float:
    """
    Compute signed flow rate Q (cfs) from signed head difference delta_h_ft = H1 - H2
    using Darcy-Weisbach + iterative friction factor.
    """
    if abs(delta_h_ft) < 1e-14:
        return 0.0

    sign = 1.0 if delta_h_ft > 0.0 else -1.0
    area = area_circular(diameter_ft)

    # Start with a reasonable guess
    q_mag = 1.0

    for _ in range(60):
        velocity = q_mag / area
        re = velocity * diameter_ft / NU
        f = friction_factor_swamee_jain(re, roughness_ft, diameter_ft)

        q_new = area * math.sqrt((2.0 * G * abs(delta_h_ft) * diameter_ft) / (f * length_ft))

        if abs(q_new - q_mag) < 1e-12:
            q_mag = q_new
            break

        q_mag = q_new

    return sign * q_mag

def head_loss_inches_water(flow_cfs: float, length_ft: float, diameter_ft: float, roughness_ft: float) -> float:
    """Return Darcy-Weisbach head loss in inches of water for a given pipe flow."""
    if abs(flow_cfs) < 1e-14:
        return 0.0

    area = area_circular(diameter_ft)
    velocity = abs(flow_cfs) / area
    re = velocity * diameter_ft / NU
    f = friction_factor_swamee_jain(re, roughness_ft, diameter_ft)

    h_loss_ft = f * (length_ft / diameter_ft) * velocity**2 / (2.0 * G)
    return h_loss_ft * 12.0
#endregion

#region data classes
@dataclass
class Node:
    """A network node."""
    name: str
    external_flow_cfs: float = 0.0
    pressure_head_ft: Optional[float] = None  # known only for fixed-pressure node(s)

@dataclass
class Pipe:
    """A pipe connecting two nodes."""
    start: str
    end: str
    length_ft: float
    diameter_ft: float
    roughness_ft: float
    flow_cfs: float = 0.0

    def reynolds(self) -> float:
        return reynolds_number(self.flow_cfs, self.diameter_ft)

    def head_loss_in_h2o(self) -> float:
        return head_loss_inches_water(self.flow_cfs, self.length_ft, self.diameter_ft, self.roughness_ft)
#endregion

#region network class
@dataclass
class PipeNetwork:
    """Object-oriented pipe network solver."""
    nodes: Dict[str, Node] = field(default_factory=dict)
    pipes: List[Pipe] = field(default_factory=list)

    def add_node(self, name: str, external_flow_cfs: float = 0.0, pressure_head_ft: Optional[float] = None) -> None:
        self.nodes[name] = Node(name=name, external_flow_cfs=external_flow_cfs, pressure_head_ft=pressure_head_ft)

    def add_pipe(self, start: str, end: str, length_ft: float, diameter_in: float, roughness_ft: float) -> None:
        self.pipes.append(
            Pipe(
                start=start,
                end=end,
                length_ft=length_ft,
                diameter_ft=diameter_in / 12.0,
                roughness_ft=roughness_ft,
            )
        )

    def solve(self) -> Dict[str, float]:
        """
        Solve for unknown nodal pressure heads using continuity at each unknown node.
        Pipe flows are computed from nodal head differences.
        """
        fixed_nodes = [n.name for n in self.nodes.values() if n.pressure_head_ft is not None]
        if len(fixed_nodes) != 1:
            raise ValueError("This solver expects exactly one fixed-pressure node for this problem.")

        fixed_node = fixed_nodes[0]
        unknown_nodes = [name for name in self.nodes if name != fixed_node]

        def residuals(x: np.ndarray) -> List[float]:
            heads = {name: value for name, value in zip(unknown_nodes, x)}
            heads[fixed_node] = self.nodes[fixed_node].pressure_head_ft

            res = []
            for node_name in unknown_nodes:
                net_inflow = 0.0

                for pipe in self.pipes:
                    q = flow_from_headloss(
                        heads[pipe.start] - heads[pipe.end],
                        pipe.length_ft,
                        pipe.diameter_ft,
                        pipe.roughness_ft,
                    )

                    if node_name == pipe.start:
                        net_inflow -= q
                    elif node_name == pipe.end:
                        net_inflow += q

                net_inflow += self.nodes[node_name].external_flow_cfs
                res.append(net_inflow)

            return res

        h_fixed = self.nodes[fixed_node].pressure_head_ft
        x0 = np.full(len(unknown_nodes), h_fixed - 1.0)
        sol = fsolve(residuals, x0)

        heads = {name: value for name, value in zip(unknown_nodes, sol)}
        heads[fixed_node] = h_fixed

        # Update node heads
        for name, head in heads.items():
            self.nodes[name].pressure_head_ft = float(head)

        # Update pipe flows
        for pipe in self.pipes:
            pipe.flow_cfs = flow_from_headloss(
                self.nodes[pipe.start].pressure_head_ft - self.nodes[pipe.end].pressure_head_ft,
                pipe.length_ft,
                pipe.diameter_ft,
                pipe.roughness_ft,
            )

        return heads

    def check_node_flows(self) -> Dict[str, float]:
        """
        Return net flow into each node.
        A correctly solved network should give values near zero.
        """
        results = {}

        for node_name, node in self.nodes.items():
            net_inflow = 0.0

            for pipe in self.pipes:
                q = pipe.flow_cfs
                if node_name == pipe.start:
                    net_inflow -= q
                elif node_name == pipe.end:
                    net_inflow += q

            net_inflow += node.external_flow_cfs
            results[node_name] = net_inflow

        return results

    def print_report(self) -> None:
        """Print the formatted report."""
        for pipe in self.pipes:
            print(
                f"The flow in segment {pipe.start}-{pipe.end} is "
                f"{pipe.flow_cfs:.2f} (cfs) and Re={pipe.reynolds():.1f}"
            )

        print("\nCheck node flows:")
        node_balance = self.check_node_flows()
        for node_name in sorted(node_balance):
            print(f"net flow into node {node_name} is {node_balance[node_name]:.2f} (cfs)")

        print("\nHead loss in each pipe:")
        for pipe in self.pipes:
            print(
                f"head loss in segment {pipe.start}-{pipe.end} is "
                f"{pipe.head_loss_in_h2o():.2f} (in H2O)"
            )

        print("\nPressure at each node:")
        for node_name in sorted(self.nodes):
            psi = head_ft_to_psi(self.nodes[node_name].pressure_head_ft)
            print(f"pressure at node {node_name} is {psi:.2f} psi")
#endregion

#region build exam network
def build_exam_problem_1_network() -> PipeNetwork:
    """
    Build the exact network from Problem 1.

    External flows inferred from the exam figure/sample output:
    - 10 cfs enters at h
    - 3 cfs leaves at e
    - 5 cfs leaves at f
    - 2 cfs leaves at d

    Known pressure:
    - node h = 80 psi
    """
    net = PipeNetwork()

    # Nodes
    for name in ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"]:
        net.add_node(name)

    net.nodes["h"].external_flow_cfs = 10.0
    net.nodes["e"].external_flow_cfs = -3.0
    net.nodes["f"].external_flow_cfs = -5.0
    net.nodes["d"].external_flow_cfs = -2.0
    net.nodes["h"].pressure_head_ft = psi_to_head_ft(80.0)

    # Pipes from exam figure
    # 18" and 24" -> concrete
    # 12" and 16" -> cast iron

    net.add_pipe("a", "b", 1000.0, 18.0, EPS_CONCRETE)
    net.add_pipe("a", "h", 1600.0, 24.0, EPS_CONCRETE)

    net.add_pipe("b", "c", 500.0, 18.0, EPS_CONCRETE)
    net.add_pipe("b", "e", 800.0, 16.0, EPS_CAST_IRON)

    net.add_pipe("c", "d", 500.0, 18.0, EPS_CONCRETE)
    net.add_pipe("c", "f", 800.0, 16.0, EPS_CAST_IRON)

    net.add_pipe("d", "g", 800.0, 16.0, EPS_CAST_IRON)

    net.add_pipe("e", "f", 500.0, 12.0, EPS_CAST_IRON)
    net.add_pipe("e", "i", 800.0, 18.0, EPS_CONCRETE)

    net.add_pipe("f", "g", 500.0, 12.0, EPS_CAST_IRON)

    net.add_pipe("g", "j", 800.0, 18.0, EPS_CONCRETE)

    net.add_pipe("h", "i", 1000.0, 24.0, EPS_CONCRETE)
    net.add_pipe("i", "j", 1000.0, 24.0, EPS_CONCRETE)

    return net
#endregion

#region main
def main() -> None:
    """
    Solve and print Problem 1 report.
    """
    network = build_exam_problem_1_network()
    network.solve()
    network.print_report()

if __name__ == "__main__":
    main()
#endregion
